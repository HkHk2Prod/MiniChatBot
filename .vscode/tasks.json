{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "[1.3M+10M] [1a] Data: download shakespeare",
      "type": "process",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "scripts/download_corpus.py",
        "--source", "tiny_shakespeare",
        "--output", "data/shakespeare/corpus.jsonl"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "[1.3M+10M] [1b] Data: tokenizer shakespeare",
      "type": "process",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "scripts/train_tokenizer.py",
        "--corpus", "data/shakespeare/corpus.jsonl",
        "--jsonl-key", "text",
        "--output", "data/shakespeare/tokenizer.json",
        "--vocab-size", "2048"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
